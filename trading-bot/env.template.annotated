# =============================================================================
# Kalshi AI Trading Bot — Environment Configuration
# Configured for DISCIPLINED LIVE MODE
#
# Instructions:
#   1. Copy this file to .env inside your cloned kalshi-ai-trading-bot directory
#   2. Replace all <PLACEHOLDER> values with your actual credentials
#   3. Never commit .env to git
# =============================================================================


# -----------------------------------------------------------------------------
# KALSHI CREDENTIALS
# Get these from: https://trading.kalshi.com/settings/api
# -----------------------------------------------------------------------------

# Your API Key ID (shown when you generate the key in Kalshi settings)
KALSHI_API_KEY=<YOUR_KALSHI_API_KEY_ID>

# Path to the RSA private key .pem file you downloaded from Kalshi
# Tip: place it in the project root as kalshi_private_key.pem
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Kalshi API base URL — do NOT change unless Kalshi updates their endpoint
KALSHI_BASE_URL=https://trading.kalshi.com/trade-api/v2


# -----------------------------------------------------------------------------
# xAI (GROK-3) — Required for 30% of ensemble weight
# Get your key from: https://console.x.ai/
# -----------------------------------------------------------------------------
XAI_API_KEY=<YOUR_XAI_API_KEY>


# -----------------------------------------------------------------------------
# OPENROUTER — Required for Claude, GPT-4o, Gemini Flash, DeepSeek R1
# Get your key from: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>


# -----------------------------------------------------------------------------
# TRADING MODE
# Set LIVE_TRADING=true to place real orders on Kalshi
# Set LIVE_TRADING=false to run in paper (simulation) mode
# Recommendation: start with false, verify setup, then switch to true
# -----------------------------------------------------------------------------
LIVE_TRADING=true


# -----------------------------------------------------------------------------
# DISCIPLINED MODE RISK LIMITS
# These override defaults in src/config/settings.py for maximum safety
# -----------------------------------------------------------------------------

# Maximum % of portfolio per single position (3% = disciplined default)
MAX_POSITION_SIZE_PCT=0.03

# Minimum AI ensemble confidence required to enter a trade (0.65 = 65%)
MIN_CONFIDENCE_THRESHOLD=0.65

# Hard stop: bot halts for the day if daily losses exceed this % of portfolio
DAILY_LOSS_LIMIT_PCT=0.15

# Maximum portfolio drawdown before full circuit breaker triggers (50%)
MAX_DRAWDOWN_PCT=0.50

# Conservative Kelly fraction (0.75 = 75% of full Kelly sizing)
KELLY_FRACTION=0.75

# Daily budget cap for all AI API calls combined
DAILY_AI_BUDGET_USD=10.0

# Minimum market volume (USD) required before the bot will analyze a market
MIN_MARKET_VOLUME=200


# -----------------------------------------------------------------------------
# DATABASE
# SQLite is used locally — no external database needed
# -----------------------------------------------------------------------------
DATABASE_PATH=./data/trades.db


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/trading.log


# -----------------------------------------------------------------------------
# PERFORMANCE TRACKING
# -----------------------------------------------------------------------------
PERFORMANCE_TRACKING=true
PERFORMANCE_REPORT_INTERVAL_MINUTES=15
